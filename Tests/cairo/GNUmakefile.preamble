# Extra build settings for the cairo backend tests.

# config.h (used by the source-level guards) sits at the top of the (build)
# tree.
ADDITIONAL_INCLUDE_DIRS += -I$(GNUSTEP_BUILD_DIR)/../.. -I../..

-include $(GNUSTEP_BUILD_DIR)/../../config.make
-include ../../config.make

# The rendering test drives the installed backend through AppKit and builds
# only for the cairo graphics backend, so link the gui there.
ifeq ($(BUILD_GRAPHICS),cairo)
ADDITIONAL_TOOL_LIBS += -lgnustep-gui
endif
